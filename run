#!/usr/bin/env bash
# Run any project script with .venv Python (creates venv on first use).
# Bare names resolve under lib/ (e.g. ./run publish_70mai.py …).
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

PY="$ROOT/.venv/bin/python"
if [[ ! -x "$PY" ]]; then
  exec "$ROOT/scripts/setup-venv.sh"
fi

if [[ $# -lt 1 ]]; then
  echo "Usage: ./run <script.py> [args...]" >&2
  echo "Example: ./run publish_70mai.py --source /Volumes/Untitled --estimate-only" >&2
  exit 1
fi

SCRIPT="$1"
shift
if [[ "$SCRIPT" != /* && "$SCRIPT" != ./* && "$SCRIPT" != ../* && "$SCRIPT" != lib/* && "$SCRIPT" != scripts/* && "$SCRIPT" != tests/* ]]; then
  if [[ -f "$ROOT/lib/$SCRIPT" ]]; then
    SCRIPT="lib/$SCRIPT"
  elif [[ -f "$ROOT/scripts/$SCRIPT" ]]; then
    SCRIPT="scripts/$SCRIPT"
  elif [[ -f "$ROOT/tests/$SCRIPT" ]]; then
    SCRIPT="tests/$SCRIPT"
  fi
fi

export PYTHONPATH="$ROOT/lib${PYTHONPATH:+:$PYTHONPATH}"
exec "$PY" "$SCRIPT" "$@"
