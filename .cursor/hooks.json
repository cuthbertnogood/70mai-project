{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/context-hygiene.py",
        "timeout": 10
      }
    ],
    "preToolUse": [
      {
        "command": ".cursor/hooks/context-hygiene.py",
        "matcher": "Write|StrReplace",
        "timeout": 10
      }
    ],
    "postToolUse": [
      {
        "command": ".cursor/hooks/context-hygiene.py",
        "matcher": "Write|StrReplace",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/auto-commit.sh",
        "timeout": 120
      }
    ]
  }
}
